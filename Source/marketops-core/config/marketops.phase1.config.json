{
  "project": "MarketOps",
  "version": "core-v0.1-minimal",
  "mode": "paper_simulation",
  "paperAccount": {
    "startingBalance": 10000,
    "targetBalance": 13000,
    "currency": "USD",
    "paperAccountPreset": "standard",
    "paperStartingBalance": 1000
  },
  "paperAccountPresets": {
    "micro": { "paperStartingBalance": 100, "label": "Micro paper account (100 paper USD)" },
    "small": { "paperStartingBalance": 250, "label": "Small paper account (250 paper USD)" },
    "standard": { "paperStartingBalance": 1000, "label": "Standard paper account (1000 paper USD)" }
  },
  "dayTrading": {
    "enabled": true,
    "maxTradesPerDay": 10,
    "maxOpenPositions": 5,
    "maxPositionSizePct": 0.25,
    "maxDailyLossPct": 0.05,
    "maxDailyDrawdownPct": 0.10,
    "cooldownMinutesAfterRejected": 15,
    "cooldownMinutesAfterClosed": 5,
    "longOnly": true,
    "marginEnabled": false,
    "leverageEnabled": false,
    "optionsEnabled": false,
    "futuresEnabled": false,
    "shortingEnabled": false,
    "cashAccountOnly": true,
    "scanCadenceMinutes": 15,
    "dashboardRefreshCadenceHours": 2
  },
  "learningMode": {
    "enabled": true,
    "profile": "aggressive_paper_learning",
    "paperOnly": true,
    "expandedUniverseTarget": 150,
    "maxOpenPositions": 40,
    "learningCandidateMovementThreshold": 1.2,
    "riskThresholds": {
      "standardApprovalMin": 0.58,
      "learningProbeMin": 0.42,
      "watchMin": 0.34,
      "hardRejectBelow": 0.34
    },
    "sizing": {
      "learningProbePositionSizeMultiplier": 0.25,
      "perTradeAllocationPct": 0.02,
      "maxLearningProbesPerDay": 10,
      "maxStandardTradesPerDay": 10,
      "maxTotalTradesPerDay": 20
    },
    "objective": {
      "prioritizeLearningEvents": true,
      "allowSmallPaperFailures": true,
      "requireFailureLabeling": true
    },
    "exitRules": {
      "maxHoldHours": 72,
      "timeStopAction": "close_at_market",
      "writelearningRecord": true,
      "unknownInstrumentDefault": "etf",
      "byInstrumentType": {
        "etf": { "targetProfitPct": 3, "stopLossPct": 2 },
        "stock": { "targetProfitPct": 6, "stopLossPct": 3 }
      }
    }
  },
  "safety": {
    "allowBrokerConnection": false,
    "allowLiveTrading": false,
    "allowSmsAlerts": false,
    "allowSubscriberSignals": false
  }
}
